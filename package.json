{
  "name": "event-ticket-monorepo",
  "private": true,
  "workspaces": [
    "modules/backend",
    "modules/ui"
  ],
  "scripts": {
    "worker": "npm run dev --workspace=modules/backend -- src/worker.js",
    "dev": "npm-run-all --parallel dev:* worker",
    "dev:backend": "npm run dev --workspace=modules/backend",
    "dev:ui": "npm run dev --workspace=modules/ui",
    "ui": "npm run dev --workspace=modules/ui",
    "backend": "npm run dev --workspace=modules/backend",
    "clean": "rimraf modules/ui/dist",
    "build:all": "npm run clean && npm run build --workspace=modules/ui",
    "start": "npm run build:all && cross-env NODE_ENV=production SERVE_UI=true npm run start --workspace=modules/backend",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "mongodb": "3.6"
  }
}
